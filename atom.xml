    <title>静态代理模式和Lamda表达式</title>
    <link href="http://yoursite.com/2020/04/07/%E9%9D%99%E6%80%81%E4%BB%A3%E7%90%86%E6%A8%A1%E5%BC%8F%E5%92%8CLamda%E8%A1%A8%E8%BE%BE%E5%BC%8F/"/>
    <id>http://yoursite.com/2020/04/07/%E9%9D%99%E6%80%81%E4%BB%A3%E7%90%86%E6%A8%A1%E5%BC%8F%E5%92%8CLamda%E8%A1%A8%E8%BE%BE%E5%BC%8F/</id>
    <published>2020-04-07T13:42:03.527Z</published>
